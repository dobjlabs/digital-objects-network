# bitcraft A2A agents — environment configuration
#
# Copy this file to `.env` (cd agents && cp .env.example .env), edit the
# values, and `bash scripts/run_all.sh` will pick them up automatically.
# `.env` is gitignored — `.env.example` is the template that's checked in.

# ============================================================================
# 1. LLM provider — pick one provider + paste its API key
# ============================================================================

# Default LLM for ALL four agents. The three specialists use LangChain +
# LiteLLM and accept any LiteLLM provider string. The Concierge uses
# BeeAI Framework, whose provider list overlaps but isn't identical —
# the LiteLLM `provider/model` shape is auto-translated to BeeAI's
# `provider:model` shape (e.g. `vertex_ai/...` → `vertexai:...`). If
# you pick a LiteLLM-only provider (e.g. `together_ai`), set
# CONCIERGE_LLM separately to a BeeAI-supported provider.
LLM_MODEL=anthropic/claude-opus-4-7

# Other examples — uncomment one to switch the whole stack:
# LLM_MODEL=gemini/gemini-2.5-flash         # Google direct, cheap + fast
# LLM_MODEL=vertex_ai/gemini-2.5-flash      # Google Vertex AI
# LLM_MODEL=openai/gpt-4o                   # OpenAI
# LLM_MODEL=ollama/llama3                   # local Ollama (no API key needed)
# LLM_MODEL=together_ai/mistralai/Mistral-7B-Instruct-v0.2
# LLM_MODEL=anthropic/claude-haiku-4-5      # cheap Anthropic option

# Per-agent overrides beat LLM_MODEL when set. Lets you mix providers
# across the network (Anthropic for one specialist, Gemini for another).
# LUMBERJACK_LLM=anthropic/claude-haiku-4-5
# STONEMASON_LLM=gemini/gemini-2.5-flash
# CRAFTSMITH_LLM=openai/gpt-4o
# CONCIERGE_LLM=anthropic:claude-opus-4-7      # BeeAI native shape
# CONCIERGE_LLM=anthropic/claude-opus-4-7      # LiteLLM shape, auto-translated

# ============================================================================
# 2. Provider API keys — set whichever provider(s) you actually use
# ============================================================================

ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENAI_API_KEY=sk-...
# TOGETHER_API_KEY=...
# Vertex AI uses gcloud Application Default Credentials, no env var

# ============================================================================
# 3. Ports & URLs — defaults below match scripts/bootstrap_dobjds.sh
# ============================================================================

# A2A agent URLs (peers find each other via these). Concierge needs to
# know the three specialists; specialists don't need to know each other.
# LUMBERJACK_URL=http://127.0.0.1:9997
# STONEMASON_URL=http://127.0.0.1:9998
# CRAFTSMITH_URL=http://127.0.0.1:9999
# CONCIERGE_URL=http://127.0.0.1:9996

# Per-agent dobjd HTTP endpoints. MCP server URL is auto-derived (port+1).
# LUMBERJACK_DOBJD=http://127.0.0.1:7717
# STONEMASON_DOBJD=http://127.0.0.1:7727
# CRAFTSMITH_DOBJD=http://127.0.0.1:7737
# CONCIERGE_DOBJD=http://127.0.0.1:7747

# ============================================================================
# 4. skill_invoke.py — used by the bitcraft-deliver-stone-pick skill
# ============================================================================

# Where the delivered StonePick .dobj lands on the user's local machine.
# Defaults to ~/.dobj/objects so dev-remote's dobjd picks it up.
# DELIVERY_DIR=/Users/you/.dobj/objects

# What the skill asks the concierge for. Change for different demos.
# REQUEST_TEXT=I want a stone pick
