# Tauri command backend integrations (used by run_sdk_action)
SYNCHRONIZER_API_URL=http://127.0.0.1:3000
RELAYER_API_URL=http://127.0.0.1:3200
RELAYER_API_KEY=dev-relayer-key

# Optional relayer polling overrides
# RELAYER_POLL_TIMEOUT_SECS=180
# RELAYER_POLL_INTERVAL_MS=1500

# Optional synchronizer indexing wait (post-relay)
# SYNCHRONIZER_POLL_TIMEOUT_SECS=120
# SYNCHRONIZER_POLL_INTERVAL_MS=1200
