# Tauri command backend integrations (used by run_sdk_action)
ZKCRAFT_SYNCHRONIZER_API_URL=http://127.0.0.1:3000
ZKCRAFT_RELAYER_API_URL=http://127.0.0.1:3200
ZKCRAFT_RELAYER_API_KEY=dev-relayer-key

# Optional relayer polling overrides
# ZKCRAFT_RELAYER_POLL_TIMEOUT_SECS=180
# ZKCRAFT_RELAYER_POLL_INTERVAL_MS=1500

# Optional synchronizer indexing wait (post-relay)
# ZKCRAFT_SYNCHRONIZER_POLL_TIMEOUT_SECS=120
# ZKCRAFT_SYNCHRONIZER_POLL_INTERVAL_MS=1200
