{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bitcraft",
  "version": "0.1.0",
  "identifier": "com.dobjlabs.bitcraft",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "bitcraft",
        "width": 1400,
        "height": 900,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "frameworks": [
        "./libs/libscip.9.2.4.0.dylib",
        "./libs/libscip.9.2.dylib",
        "./libs/libscip.dylib",
        "./libs/libgfortran.5.dylib",
        "./libs/libquadmath.0.dylib",
        "./libs/libgcc_s.1.1.dylib"
      ]
    },
    "linux": {
      "appimage": {
        "files": {
          "/usr/lib/app-gui/libs": "libs/"
        }
      },
      "deb": {
        "files": {
          "/usr/lib/app-gui/libs": "libs/"
        }
      },
      "rpm": {
        "files": {
          "/usr/lib/app-gui/libs": "libs/"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
