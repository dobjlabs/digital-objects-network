[Unit]
Description=bitcraft relayer
After=network-online.target postgresql.service synchronizer.service
Wants=network-online.target

[Service]
Type=simple
User=zkcraft
Group=zkcraft
WorkingDirectory=/srv/zkcraft/repo
EnvironmentFile=/etc/zkcraft/relayer.env
ExecStart=/srv/zkcraft/repo/target/release/relayer
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
