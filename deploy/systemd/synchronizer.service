[Unit]
Description=bitcraft synchronizer
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=zkcraft
Group=zkcraft
WorkingDirectory=/srv/zkcraft/repo
EnvironmentFile=/etc/zkcraft/synchronizer.env
ExecStart=/srv/zkcraft/repo/target/release/synchronizer
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
