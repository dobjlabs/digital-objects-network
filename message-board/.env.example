# message-board server bind address
MESSAGE_BOARD_BIND=127.0.0.1:3100

# required: Postgres connection string
# example:
# postgres://postgres:postgres@localhost:5432/zkcraft
MESSAGE_BOARD_DATABASE_URL=postgres://postgres:postgres@localhost:5432/zkcraft

# CORS origin for browser clients; use * for local dev
MESSAGE_BOARD_CORS_ORIGIN=*

# max allowed `limit` for GET /api/v1/posts
MESSAGE_BOARD_MAX_PAGE_SIZE=50
