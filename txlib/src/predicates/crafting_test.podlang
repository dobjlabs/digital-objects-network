/*
  Minimal crafting predicates for testing the actions-based txlib.
  Simplified: no VDF, no key rotation, no LtEqU256. Focuses on
  structural correctness of actions, replay, and guard dispatch.
*/

use module 0xTXLIB_MODULE_HASH as tx

// ========================================================
// Deletion Sub-Actions
// ========================================================

DeleteLog(log, chain_start, chain_end) = AND(
  DictContains(log, "type", @self_predicate(IsLog))
  tx::TxDelete(chain_end, chain_start, log)
)

DeleteWood(wood, chain_start, chain_end) = AND(
  DictContains(wood, "type", @self_predicate(IsWood))
  tx::TxDelete(chain_end, chain_start, wood)
)

DeleteStick(stick, chain_start, chain_end) = AND(
  DictContains(stick, "type", @self_predicate(IsStick))
  tx::TxDelete(chain_end, chain_start, stick)
)

// ========================================================
// Actions
// ========================================================

// FindLog: creates a log from nothing (simplified: no VDF).
FindLog(log, chain_start, chain_end) = AND(
  DictContains(log, "type", @self_predicate(IsLog))
  tx::TxInsert(chain_end, chain_start, log)
)

// CraftWood: consumes a log, produces wood (simplified: no LtEqU256).
CraftWood(wood, chain_start, chain_end,
    private: h0, log) = AND(
  DeleteLog(log, chain_start, h0)
  DictContains(wood, "type", @self_predicate(IsWood))
  tx::TxInsert(chain_end, h0, wood)
)

// CraftSticks: consumes wood, produces two sticks.
CraftSticks(stick_a, stick_b, chain_start, chain_end,
    private: h0, h1, wood) = AND(
  DeleteWood(wood, chain_start, h0)
  DictContains(stick_a, "type", @self_predicate(IsStick))
  tx::TxInsert(h1, h0, stick_a)
  DictContains(stick_b, "type", @self_predicate(IsStick))
  tx::TxInsert(chain_end, h1, stick_b)
)

// CraftWoodPick: consumes wood + stick, produces wood pick.
CraftWoodPick(wood_pick, chain_start, chain_end,
    private: h0, h1, wood, stick) = AND(
  DeleteWood(wood, chain_start, h0)
  DeleteStick(stick, h0, h1)
  DictContains(wood_pick, "type", @self_predicate(IsWoodPick))
  DictContains(wood_pick, "durability", 100)
  tx::TxInsert(chain_end, h1, wood_pick)
)

// UseWoodPick: mutates a wood pick, decrementing durability.
// Simplified: no VDF, no key rotation.
UseWoodPick(wood_pick, chain_start, chain_end,
    private: wood_pick0, durability) = AND(
  DictContains(wood_pick0, "type", @self_predicate(IsWoodPick))
  Gt(wood_pick0.durability, 0)
  SumOf(wood_pick0.durability, durability, 1)
  DictUpdate(wood_pick, wood_pick0, "durability", durability)
  tx::TxMutate(chain_end, chain_start, wood_pick, wood_pick0)
)

// MineStone: uses a wood pick to mine stone.
MineStone(stone, chain_start, chain_end,
    private: h0, pick) = AND(
  UseWoodPick(pick, chain_start, h0)
  DictContains(stone, "type", @self_predicate(IsStone))
  tx::TxInsert(chain_end, h0, stone)
)

// SpawnWoodPick: test-only action that creates a wood pick from nothing.
SpawnWoodPick(wood_pick, chain_start, chain_end) = AND(
  DictContains(wood_pick, "type", @self_predicate(IsWoodPick))
  DictContains(wood_pick, "durability", 100)
  tx::TxInsert(chain_end, chain_start, wood_pick)
)

// ========================================================
// Type Guards
// ========================================================

IsLog(obj, chain_start, chain_end) = OR(
  FindLog(obj, chain_start, chain_end)
  DeleteLog(obj, chain_start, chain_end)
)

IsWood(obj, chain_start, chain_end) = OR(
  CraftWood(obj, chain_start, chain_end)
  DeleteWood(obj, chain_start, chain_end)
)

IsStick(obj, chain_start, chain_end, private: other) = OR(
  DeleteStick(obj, chain_start, chain_end)
  CraftSticks(obj, other, chain_start, chain_end)
  CraftSticks(other, obj, chain_start, chain_end)
)

IsWoodPick(obj, chain_start, chain_end) = OR(
  SpawnWoodPick(obj, chain_start, chain_end)
  CraftWoodPick(obj, chain_start, chain_end)
  UseWoodPick(obj, chain_start, chain_end)
)

IsStone(obj, chain_start, chain_end) = OR(
  MineStone(obj, chain_start, chain_end)
)
